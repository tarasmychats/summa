{
  "name": "@wealthtrack/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:db": "docker compose up -d postgres",
    "dev:db:stop": "docker compose down",
