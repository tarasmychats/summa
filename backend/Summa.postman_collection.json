    {
      "name": "Auth",
      "item": [
        {
          "name": "Create Anonymous User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.collectionVariables.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/anonymous",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "anonymous"]
            },
            "description": "Create an anonymous user and receive JWT tokens. Auto-saves accessToken and refreshToken."
          },
          "response": []
        },
        {
          "name": "Apple Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.collectionVariables.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identityToken\": \"<paste-apple-identity-token-here>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/apple",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "apple"]
            },
            "description": "Sign in with Apple identity token. Auto-saves accessToken and refreshToken."
          },
          "response": []
        },
        {
          "name": "Merge Anonymous into Apple",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.collectionVariables.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anonymousToken\": \"{{accessToken}}\",\n  \"identityToken\": \"<paste-apple-identity-token-here>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/merge",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "merge"]
            },
            "description": "Merge anonymous account data into an Apple account. Auto-saves new tokens."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.collectionVariables.set('accessToken', res.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Refresh the access token. Auto-saves new accessToken."
          },
          "response": []
        }
      ]
    },
